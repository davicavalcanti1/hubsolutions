# HubSolutions — server/.env

# Supabase — Dashboard → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Banco — Supabase Dashboard → Settings → Database → Connection string (URI)
# Usar Transaction mode (porta 6543) para melhor performance
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Em produção: URL pública do app (para CORS)
FRONTEND_URL=http://localhost:5173
PORT=3001
