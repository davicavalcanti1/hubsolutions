# ============================================================
# HubSolutions — server/.env
# ============================================================

# Supabase (obrigatório)
# URL e anon key: Supabase Dashboard → Settings → API
# JWT Secret:     Supabase Dashboard → Settings → API → JWT Settings
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE=your-service-role-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Banco de dados local (PostgreSQL no EasyPanel)
DB_HOST=db
DB_PORT=5432
DB_NAME=hubsolutions
DB_USER=hubsolutions_user
DB_PASSWORD=troque-esta-senha-forte

# Frontend (CORS)
FRONTEND_URL=https://app.seudominio.com

# Porta do servidor
PORT=3001
